{
  "name": "@flixora/zeptpay-payment-core",
  "version": "0.0.4",
  "description": "Official Node.js SDK for ZeptPay Payment Gateway - Enterprise Edition",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE.md",
    "SECURITY.md",
    "tsconfig.json"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc --project tsconfig.json --outDir dist && cpx \"src/types/**/*\" dist/types && copyfiles -u 1 src/assets/**/* dist",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tafseelkhan/zeptpay-payment-core.git"
  },
  "keywords": [
    "zeptpay",
    "payment",
    "core",
    "flixora"
  ],
  "author": "Tafseel Khan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tafseelkhan/zeptpay-payment-core/issues"
  },
  "homepage": "https://github.com/tafseelkhan/zeptpay-payment-core#readme",
  "devDependencies": {
    "@types/node": "^25.3.5",
    "axios": "^1.13.6",
    "copyfiles": "^2.4.1",
    "cpx": "^1.5.0",
    "typescript": "^5.9.3"
  }
}
